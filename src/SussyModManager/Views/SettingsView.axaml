<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SussyModManager.ViewModels"
             x:Class="SussyModManager.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Margin="28,24,28,24" Spacing="20" MaxWidth="900" HorizontalAlignment="Left">

            <StackPanel Spacing="2">
                <TextBlock Text="{Binding Title}" Classes="h1" />
                <TextBlock Text="{Binding Subtitle}" Classes="muted" />
            </StackPanel>

            <!-- Game setup -->
            <Border Classes="card">
                <StackPanel Spacing="14">
                    <TextBlock Text="Game" Classes="h2" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Among Us folder" Classes="muted" />
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" >
                            <TextBox Grid.Column="0" Text="{Binding AmongUsPath}"
                                     Watermark="Path to your Among Us install folder" />
                            <Button Grid.Column="1" Classes="ghost" Content="Browse"
                                    Margin="8,0,0,0" Click="OnBrowse" />
                            <Button Grid.Column="2" Classes="ghost" Content="Detect"
                                    Margin="8,0,0,0" Command="{Binding DetectCommand}" />
                            <Button Grid.Column="3" Classes="accent" Content="Save"
                                    Margin="8,0,0,0" Command="{Binding SavePathCommand}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Game channel" Classes="muted" />
                        <ComboBox ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannel}"
                                  MinWidth="240" HorizontalAlignment="Left" />
                    </StackPanel>

                    <CheckBox Content="Show beta / pre-release versions" IsChecked="{Binding ShowBetaVersions}"
                              Foreground="{DynamicResource TextPrimaryBrush}" />

                    <Grid ColumnDefinitions="Auto,*,Auto" >
                        <TextBlock Grid.Column="0" Text="BepInEx:" Classes="muted" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding BepInExStatus}" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <Button Grid.Column="2" Classes="ghost" Content="Install / Update BepInEx"
                                Command="{Binding InstallBepInExCommand}" IsEnabled="{Binding !IsBusy}" />
                    </Grid>

                    <TextBlock Classes="muted" FontSize="12"
                               Text="{Binding PlatformLabel, StringFormat='Running on {0}. On Linux/macOS the game launches through Steam (Proton/Wine).'}" />
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Classes="card">
                <StackPanel Spacing="14">
                    <TextBlock Text="Appearance" Classes="h2" />
                    <TextBlock Text="Pick a color profile. The whole app recolors instantly."
                               Classes="muted" />

                    <ItemsControl ItemsSource="{Binding Profiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ColorProfileViewModel">
                                <Button Classes="ghost" Margin="0,0,12,12" Padding="12"
                                        Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).ApplyProfileCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Spacing="8" Width="150">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="{Binding AccentSwatch}" />
                                            <Border Width="26" Height="26" CornerRadius="6" Background="{Binding SecondarySwatch}" />
                                            <Border Width="26" Height="26" CornerRadius="6" Background="{Binding SurfaceSwatch}" />
                                            <Border Width="26" Height="26" CornerRadius="6" Background="{Binding BackgroundSwatch}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="●" Foreground="{DynamicResource SuccessBrush}"
                                                       IsVisible="{Binding IsActive}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Custom accent (hex)" Classes="muted" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding CustomAccent}" Width="160" Watermark="#8B5CF6" />
                            <Button Classes="accent" Content="Apply accent" Command="{Binding ApplyCustomAccentCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Live preview -->
                    <Border Classes="card" Background="{DynamicResource SurfaceElevatedBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Preview" Classes="muted" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource AccentBrush}">
                                    <TextBlock Text="S" FontSize="22" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Town of Us Mira" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="AU-Avengers" Classes="muted" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="accent" Content="Install" />
                                <Button Classes="success" Content="Play" />
                                <Button Classes="danger" Content="Remove" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Updates -->
            <Border Classes="card">
                <StackPanel Spacing="14">
                    <TextBlock Text="Updates" Classes="h2" />
                    <TextBlock Text="{Binding AppVersionLabel}" Classes="muted" />

                    <CheckBox Content="Automatically download and install app updates"
                              IsChecked="{Binding AutoUpdateApp}"
                              Foreground="{DynamicResource TextPrimaryBrush}" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Classes="accent" Content="Check for updates now"
                                Command="{Binding CheckForUpdatesCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding UpdateStatus}" Classes="muted" TextWrapping="Wrap"
                               IsVisible="{Binding UpdateStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </Border>

            <!-- Danger zone -->
            <Border Classes="card" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Danger zone" Classes="h2" Foreground="{DynamicResource DangerBrush}" />
                    <TextBlock Classes="muted" TextWrapping="Wrap"
                               Text="Restore your game to a clean, unmodded state. Use this if mods misbehave or a bad BepInEx got stuck. Your Among Us game files are never touched - only modding files are removed." />

                    <CheckBox Content="I understand - enable the buttons below"
                              IsChecked="{Binding ArmDangerZone}"
                              Foreground="{DynamicResource TextPrimaryBrush}" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Classes="ghost" Content="Convert game to vanilla (keep downloads)"
                                Command="{Binding ConvertToVanillaCommand}"
                                IsEnabled="{Binding ArmDangerZone}" />
                        <Button Classes="danger" Content="Remove ALL mods + restore vanilla"
                                Command="{Binding RestoreVanillaCommand}"
                                IsEnabled="{Binding ArmDangerZone}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
