<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SussyModManager.ViewModels"
             xmlns:views="clr-namespace:SussyModManager.Views"
             x:Class="SussyModManager.Views.StoreView"
             x:DataType="vm:StoreViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="28,24,28,16">

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="{Binding Title}" Classes="h1" />
            <TextBlock Text="{Binding Subtitle}" Classes="muted" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,18,0,16">
            <TextBox Grid.Column="0" Watermark="Search mods, authors, descriptions..."
                     Text="{Binding SearchText}" MaxWidth="520" HorizontalAlignment="Left" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding InstallFilters}"
                      SelectedItem="{Binding SelectedInstallFilter}" MinWidth="150" Margin="8,0,0,0" />
            <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}" MinWidth="170" Margin="8,0,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Mods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ModCardViewModel">
                        <views:ModCardView />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
