<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SussyModManager.ViewModels"
             x:Class="SussyModManager.Views.ModCardView"
             x:DataType="vm:ModCardViewModel">

    <Border Classes="card" Width="330" Height="196" Margin="8">
        <Grid RowDefinitions="Auto,*,Auto,Auto">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12"
                        Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                    <TextBlock Text="{Binding Initial}" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15"
                               Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Author}" Classes="muted" FontSize="12" />
                </StackPanel>

                <Border Grid.Column="2" Classes="badge" VerticalAlignment="Top"
                        IsVisible="{Binding IsFeatured}">
                    <TextBlock Text="FEATURED" />
                </Border>
            </Grid>

            <!-- Description -->
            <TextBlock Grid.Row="1" Text="{Binding Description}" Classes="muted"
                       TextWrapping="Wrap" MaxLines="3" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Top" />

            <!-- Footer -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}"
                              Command="{Binding ToggleSelectCommand}"
                              IsVisible="{Binding ShowLaunchCheckbox}"
                              Content="Launch"
                              Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="Auto (dependency)" Classes="muted" FontSize="11"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsDependency}"
                               ToolTip.Tip="Included automatically when a mod you launch needs it." />
                    <TextBlock Text="{Binding StatusText}" Classes="muted" FontSize="11"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsInstalled}" />
                    <TextBlock Text="{Binding LatestVersion, StringFormat='→ {0}'}" FontSize="11"
                               Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"
                               IsVisible="{Binding HasUpdate}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Classes="accent" Content="Install"
                            Command="{Binding InstallCommand}"
                            IsVisible="{Binding ShowInstallButton}"
                            IsEnabled="{Binding !IsBusy}" />
                    <Button Classes="success" Content="Update"
                            Command="{Binding UpdateCommand}"
                            IsVisible="{Binding ShowUpdateButton}"
                            IsEnabled="{Binding !IsBusy}" />
                    <Button Classes="danger" Content="Remove"
                            Command="{Binding UninstallCommand}"
                            IsVisible="{Binding IsInstalled}"
                            IsEnabled="{Binding !IsBusy}" />
                </StackPanel>
            </Grid>

            <!-- Busy indicator -->
            <ProgressBar Grid.Row="3" Margin="0,8,0,0" IsIndeterminate="True" Height="3"
                         IsVisible="{Binding IsBusy}"
                         Foreground="{DynamicResource AccentBrush}" />
        </Grid>
    </Border>
</UserControl>
